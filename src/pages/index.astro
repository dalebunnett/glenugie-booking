---
import MainLayout from '../layouts/main.astro';
import { Button } from '../components/ui/button';
import { baseUrl } from '../lib/base-url';

const schema = {
  "@context": "https://schema.org",
  "@type": "PetStore",
  "name": "Glenugie Kennels",
  "description": "Premium dog and cat1 boarding with luxury themed suites in Peterhead, Aberdeenshire. Featuring 10 luxury dog suites, 13 cattery suites, and standard kennels with professional care.",
  "image": "https://cdn.prod.website-files.com/69ea97152f20066bc07c2195/69f5d3c693d50ca27dfe5a52_PHOTO-2026-05-02-11-29-06.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Glenugie",
    "addressLocality": "Peterhead",
    "addressRegion": "Aberdeenshire",
    "postalCode": "AB42 3EQ",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "57.5089",
    "longitude": "-1.7845"
  },
  "url": "https://glenugiekennels.co.uk",
  "telephone": "+44-1779-841393",
  "email": "info@glenugiekennels.co.uk",
  "priceRange": "££",
  "openingHours": "Mo-Su 14:00-17:00",
  "areaServed": ["Peterhead", "Aberdeen", "Fraserburgh", "Ellon", "Aberdeenshire", "Scotland"],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "150",
    "bestRating": "5",
    "worstRating": "1"
  },
  "hasMap": "https://maps.google.com/?cid=8993054838066790595"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What types of pet boarding do you offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer luxury dog suites, standard kennels, and luxury cattery suites. Our facility includes 10 themed luxury dog suites, standard kennels, and 13 individually designed cattery suites, all with professional care and premium amenities."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Glenugie Kennels located?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Glenugie Kennels is located in Glenugie, Peterhead, Aberdeenshire, AB42 3EQ. We serve Peterhead, Aberdeen, Fraserburgh, Ellon, and the wider Aberdeenshire area."
      }
    },
    {
      "@type": "Question",
      "name": "What is included in the boarding price?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All stays include premium Eukanuba food, fresh water, daily exercise and play, professional care, medication distribution, 24/7 supervision, and a complimentary bath and blow-dry for stays of 7+ nights. Luxury suites also include themed décor, raised beds with premium bedding, and access to Fairytails Spa."
      }
    },
    {
      "@type": "Question",
      "name": "How much does pet boarding cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Luxury dog suites are £25 per night, standard kennels are £20 per night, and cattery suites are £15 per night. Additional pets from the same family cost £7.50-£10 per night depending on the accommodation type."
      }
    },
    {
      "@type": "Question",
      "name": "Can I book online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! You can check real-time availability and book your pet's stay online through our website. You'll receive instant confirmation and can manage your booking through our customer portal."
      }
    }
  ]
};

const combinedSchema = {
  "@context": "https://schema.org",
  "@graph": [schema, faqSchema]
};
---

<MainLayout 
  pageClass=""
  title="Glenugie Kennels | Luxury Dog & Cat Boarding in Peterhead, Aberdeenshire"
  description="Premium pet boarding with themed luxury suites, professional care, and spa services. 10 dog suites, 13 cattery suites, and standard kennels. Serving Peterhead, Aberdeen & Aberdeenshire. Book online today!"
  keywords="dog kennels Peterhead, cat boarding Aberdeenshire, luxury pet boarding Scotland, dog hotel Aberdeen, cattery near me, pet boarding Peterhead, luxury dog suites, cat kennels Aberdeen"
  ogImage="https://cdn.prod.website-files.com/69ea97152f20066bc07c2195/69f5d3c693d50ca27dfe5a52_PHOTO-2026-05-02-11-29-06.jpg"
  schema={combinedSchema}
>
<script src="//unpkg.com/alpinejs" defer></script>

