// Find the accommodation by slug
const accommodation = accommodations.find(acc => acc.slug === slug);

// Redirect if not found
if (!accommodation) {
  return Astro.redirect(`${baseUrl}/accommodations`);
}

// SEO content based on accommodation type
const seoTitle = `${accommodation.name} - ${accommodation.type} | Glenugie Kennels`;
const seoDescription = accommodation.description 
  ? `${accommodation.description.substring(0, 150)}... Book from £${accommodation.price}/night. Professional care, premium amenities. View availability and book online.`
  : `Book ${accommodation.name} - ${accommodation.type} at Glenugie Kennels from £${accommodation.price}/night. Professional care, luxury accommodation, and premium amenities in Peterhead.`;
const seoKeywords = accommodation.category === 'luxury'
  ? `${accommodation.name}, luxury dog suite Peterhead, themed dog kennel, premium dog boarding, ${accommodation.name} book online`
  : accommodation.category === 'cattery'
  ? `${accommodation.name}, luxury cat suite Peterhead, cat boarding Aberdeen, cattery Aberdeenshire, ${accommodation.name} availability`
  : `${accommodation.name}, standard kennels Peterhead, dog boarding, affordable kennels Aberdeen`;

const kennelSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${accommodation.name} - ${accommodation.type}`,
  "description": accommodation.description,
  "image": accommodation.image,
  "brand": {
    "@type": "Brand",
    "name": "Glenugie Kennels"
  },
  "offers": {
    "@type": "Offer",
    "price": accommodation.price.toString(),
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock",
    "priceValidUntil": "2027-12-31",
    "url": `https://glenugiekennels.co.uk/kennels/${accommodation.slug}`
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "150"
  }
};

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://glenugiekennels.co.uk"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Kennels & Suites",
      "item": "https://glenugiekennels.co.uk/accommodations"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": accommodation.name,
      "item": `https://glenugiekennels.co.uk/kennels/${accommodation.slug}`
    }
  ]
};

// Combine schemas
const combinedSchema = {
  "@context": "https://schema.org",
  "@graph": [kennelSchema, breadcrumbSchema]
};

const categoryFeatures = {
  luxury: [
    { icon: '🏠', text: 'Luxury Suite Accommodation' },
    { icon: '🛏️', text: 'Premium Bedding' },
    { icon: '🍽️', text: 'Gourmet Meals Included' },
    { icon: '🎾', text: 'Daily Exercise & Play' },
    { icon: '🛁', text: 'Free Bath & Blow-Dry' },
    { icon: '💆', text: 'Access to Fairytails Spa' },
    { icon: '❤️', text: 'Individual Attention' },
  ],
  standard: [
    { icon: '🏠', text: 'Comfortable Kennel' },
    { icon: '🛏️', text: 'Cozy Bedding' },
    { icon: '🍽️', text: 'Quality Meals Included' },
    { icon: '🎾', text: 'Daily Exercise & Play' },
    { icon: '🛁', text: 'Free Bath & Blow-Dry' },
    { icon: '💆', text: 'Access to Fairytails Spa' },
    { icon: '❤️', text: 'Caring Staff' },
  ],
  cattery: [
    { icon: '🏠', text: 'Spacious Cat Suite' },
    { icon: '🛏️', text: 'Comfortable Bedding' },
    { icon: '🍽️', text: 'Premium Cat Meals' },
    { icon: '🪟', text: 'Window Views' },
    { icon: '🧸', text: 'Toys & Entertainment' },
    { icon: '❤️', text: 'Individual Care' },
  ],
};
---
<MainLayout 
  pageClass=""
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage={accommodation.image}
  schema={combinedSchema}
>
  <div class="min-h-screen bg-background">
    <!-- Header -->
    <section class="bg-primary text-primary-foreground py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <a href={`${baseUrl}/accommodations`} class="text-primary-foreground/80 hover:text-primary-foreground inline-flex items-center gap-2 mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Kennels and Suites
          </a>
          <h1 class="text-4xl md:text-5xl font-bold mb-2">{accommodation.name}</h1>
          <p class="text-xl opacity-90">{accommodation.type}</p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="grid md:grid-cols-2 gap-12">
          <!-- Image Gallery -->
          <div>
            <div class="space-y-4">
              <!-- Main Image -->
              {accommodation.image ? (
                <img 
                  src={accommodation.image} 
                  alt={accommodation.name}
                  class="w-full h-auto rounded-lg shadow-lg"
                />
              ) : (
                <div class="w-full aspect-video bg-gradient-to-br from-primary/20 to-primary/5 rounded-lg shadow-lg flex items-center justify-center">
                  <div class="text-center">
                    <div class="text-6xl mb-4">
                      {accommodation.category === 'cattery' ? '🐱' : '🐕'}
                    </div>
                    <p class="text-muted-foreground">Image coming soon</p>
                  </div>
                </div>
              )}
              
              <!-- Additional Gallery Images -->
              {accommodation.gallery && accommodation.gallery.length > 1 && (
                <div class="grid grid-cols-1 gap-4">
                  {accommodation.gallery.slice(1).map((img: string) => (
                    <img 
                      src={img} 
                      alt={`${accommodation.name} - Gallery`}
                      class="w-full h-auto rounded-lg shadow-md hover:shadow-xl transition-shadow cursor-pointer"
                    />
                  ))}
                </div>
              )}
            </div>
          </div>

          <!-- Details -->
          <div>
            <div class="mb-6">
              <Badge variant={accommodation.category === 'luxury' ? 'secondary' : 'outline'} className="mb-4">
                {accommodation.category === 'luxury' ? 'Premium' : accommodation.category === 'cattery' ? 'Cattery' : 'Standard'}
              </Badge>
              
              <!-- Prominent Book Now Button -->
              <div class="mb-6">
                <a 
                  href={`${baseUrl}/booking?suite=${accommodation.slug}&type=${accommodation.category === 'cattery' ? 'cat' : 'dog'}&accommodation=${accommodation.category === 'luxury' ? 'luxury-suite' : accommodation.category === 'cattery' ? 'cattery' : accommodation.slug}`} 
                  class="block"
                >
                  <Button size="lg" className="w-full text-xl py-7 bg-primary hover:bg-primary/90 shadow-lg hover:shadow-xl transition-all">
                    🐾 Book {accommodation.name} Now
                  </Button>
                </a>
              </div>

              <h2 class="text-3xl font-bold mb-4">About This Suite</h2>
              {accommodation.description ? (
                <p class="text-lg text-muted-foreground leading-relaxed mb-6">
                  {accommodation.description}
                </p>
              ) : (
                <p class="text-lg text-muted-foreground leading-relaxed mb-6">
                  Experience luxury accommodation at its finest. This beautifully themed suite provides 
                  the perfect home away from home for your beloved companion, with premium amenities 
                  and personalized care from our dedicated staff.
                </p>
              )}
            </div>

            <!-- Pricing -->
            <Card className="mb-6">
              <CardHeader>
                <CardTitle>Pricing</CardTitle>
              </CardHeader>
              <CardContent>
                <div class="space-y-3">
                  <div class="flex justify-between items-center">
                    <span class="text-muted-foreground">Per Night</span>
                    <span class="text-2xl font-bold text-primary">£{accommodation.price}</span>
                  </div>
                  <div class="flex justify-between items-center text-sm">
                    <span class="text-muted-foreground">Additional Pet (same family)</span>
                    <span class="font-semibold">+£{accommodation.sharingPrice}/night</span>
                  </div>
                  <div class="pt-3 border-t">
                    <p class="text-sm text-muted-foreground">
                      Maximum {accommodation.maxOccupancy} pets per suite (same family only)
                    </p>
                  </div>
                </div>
              </CardContent>
            </Card>

            <!-- Availability Calendar -->
            <div class="mb-6">
              <KennelAvailabilityCalendar 
                client:load
                kennelSlug={accommodation.slug}
                kennelName={accommodation.name}
                accommodationType={accommodation.category === 'luxury' ? 'luxury-suite' : accommodation.category === 'cattery' ? 'cattery' : accommodation.slug === 'ruffs-retreat' ? 'ruffs-retreat' : 'village'}
              />
            </div>

            <!-- Features -->
            <div class="mb-12">
              <h2 class="text-3xl font-normal mb-6 text-primary">What's Included</h2>
              <div class="grid md:grid-cols-2 gap-4">
                {accommodation.features.map((feature: string) => (
                  <div class="flex items-start gap-3 bg-card p-4 rounded-xl border border-border">
                    <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-foreground">{feature}</span>
                  </div>
                ))}
              </div>
              
              <!-- Disclaimer Notice -->
              <div class="mt-6 bg-primary/5 border border-primary/20 rounded-xl p-4">
                <p class="text-sm text-muted-foreground text-center">
                  <strong>Please note:</strong> Some decorative items shown in photos are purely for display purposes and may be removed or changed. Room layouts and décor are subject to change to ensure the safety and comfort of all our guests.
                </p>
              </div>
            </div>

            <!-- CTA -->
            <div class="flex gap-4">
              <a 
                href={`${baseUrl}/booking?suite=${accommodation.slug}&type=${accommodation.category === 'cattery' ? 'cat' : 'dog'}&accommodation=${accommodation.category === 'luxury' ? 'luxury-suite' : accommodation.category === 'cattery' ? 'cattery' : accommodation.slug}`} 
                class="flex-1"
              >
                <Button size="lg" className="w-full text-lg py-6">
                  🐾 Book {accommodation.name} Now
                </Button>
              </a>
              <a href={`${baseUrl}/contact`}>
                <Button size="lg" variant="outline" className="py-6">Ask a Question</Button>
              </a>
            </div>
          </div>
        </div>

        <!-- What's Included -->
        <div class="mt-16 bg-gradient-to-br from-primary/5 to-primary/10 rounded-lg p-8">
          <h3 class="text-3xl font-bold mb-6 text-center">What's Included in Every Stay</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg p-4">
              <div class="text-4xl mb-2">🍽️</div>
              <h4 class="font-semibold mb-2">Premium Cuisine</h4>
              <p class="text-sm text-muted-foreground">
                Premium Eukanuba food with special dietary requirements accommodated
              </p>
            </div>
            <div class="bg-white rounded-lg p-4">
              <div class="text-4xl mb-2">💧</div>
              <h4 class="font-semibold mb-2">Fresh Water</h4>
              <p class="text-sm text-muted-foreground">
                Finest fresh Northeast water, always available
              </p>
            </div>
            <div class="bg-white rounded-lg p-4">
              <div class="text-4xl mb-2">💊</div>
              <h4 class="font-semibold mb-2">Medication Care</h4>
              <p class="text-sm text-muted-foreground">
                All medications distributed according to your instructions
              </p>
            </div>
            {accommodation.category !== 'cattery' && (
              <div class="bg-white rounded-lg p-4">
                <div class="text-4xl mb-2">🛁</div>
                <h4 class="font-semibold mb-2">Free Bath & Blow-Dry</h4>
                <p class="text-sm text-muted-foreground">
                  Complimentary bath and blow-dry for stays of 7+ nights
                </p>
              </div>
            )}
            <div class="bg-white rounded-lg p-4">
              <div class="text-4xl mb-2">🏥</div>
              <h4 class="font-semibold mb-2">Health Monitoring</h4>
              <p class="text-sm text-muted-foreground">
                Professional care with attention to dietary needs
              </p>
            </div>
            {accommodation.category !== 'cattery' && (
              <div class="bg-white rounded-lg p-4">
                <div class="text-4xl mb-2">🎾</div>
                <h4 class="font-semibold mb-2">Exercise & Play</h4>
                <p class="text-sm text-muted-foreground">
                  Daily exercise sessions and supervised playtime
                </p>
              </div>
            )}
          </div>
