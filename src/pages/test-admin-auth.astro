

---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
  <div class="container mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8">Admin Authentication Test</h1>
    
    <div class="bg-yellow-100 border-l-4 border-yellow-500 p-4 mb-6">
      <p class="text-sm font-semibold">Testing on: <span class="font-mono" id="currentUrl"></span></p>
      <p class="text-xs mt-1">Base URL: <span class="font-mono">{baseUrl}</span></p>
    </div>
    
    <div class="space-y-4 max-w-2xl">
      <div class="bg-card p-6 rounded-lg border">
        <h2 class="text-xl font-semibold mb-4">Step 1: Login</h2>
        <div class="space-y-3">
          <input 
            type="password" 
            id="password" 
            placeholder="Enter admin password" 
            class="w-full px-4 py-2 border rounded"
          />
          <button 
            id="loginBtn" 
            class="bg-primary text-primary-foreground px-6 py-2 rounded hover:opacity-90"
          >
            Login
          </button>
          <div id="loginResult" class="text-sm"></div>
        </div>
      </div>

      <div class="bg-card p-6 rounded-lg border">
        <h2 class="text-xl font-semibold mb-4">Step 2: Check Debug Info</h2>
        <button 
          id="debugBtn" 
          class="bg-secondary text-secondary-foreground px-6 py-2 rounded hover:opacity-90 mb-3"
        >
          Get Debug Info
        </button>
        <pre id="debugResult" class="bg-muted p-4 rounded text-xs overflow-auto max-h-96"></pre>
      </div>

      <div class="bg-card p-6 rounded-lg border">
        <h2 class="text-xl font-semibold mb-4">Step 3: Test API Access</h2>
        <button 
          id="testBtn" 
          class="bg-secondary text-secondary-foreground px-6 py-2 rounded hover:opacity-90 mb-3"
        >
          Test /api/admin/bookings
        </button>
        <pre id="testResult" class="bg-muted p-4 rounded text-xs overflow-auto max-h-96"></pre>
      </div>

      <div class="bg-card p-6 rounded-lg border">
        <h2 class="text-xl font-semibold mb-4">Current Cookies</h2>
        <pre id="cookies" class="bg-muted p-4 rounded text-xs overflow-auto"></pre>
        <button 
          id="refreshCookies" 
          class="mt-3 bg-secondary text-secondary-foreground px-4 py-2 rounded hover:opacity-90 text-sm"
        >
          Refresh
        </button>
      </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ baseUrl }}>
  // Show current URL
  document.getElementById('currentUrl').textContent = window.location.href;
  
  const showCookies = () => {
    document.getElementById('cookies').textContent = document.cookie || '(no cookies)';
  };

  showCookies();

  document.getElementById('refreshCookies').addEventListener('click', showCookies);

  document.getElementById('loginBtn').addEventListener('click', async () => {
    const password = document.getElementById('password').value;
    const resultDiv = document.getElementById('loginResult');
    
    try {
      const response = await fetch(`${baseUrl}/api/admin/auth`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ password })
      });
      
      const data = await response.json();
      resultDiv.textContent = JSON.stringify(data, null, 2);
      resultDiv.className = response.ok ? 'text-sm text-green-600' : 'text-sm text-red-600';
      
      showCookies();
    } catch (error) {
      resultDiv.textContent = `Error: ${error.message}`;
      resultDiv.className = 'text-sm text-red-600';
    }
  });

  document.getElementById('debugBtn').addEventListener('click', async () => {
    const resultDiv = document.getElementById('debugResult');
    
    try {
      const response = await fetch(`${baseUrl}/api/admin/debug-session`, {
        credentials: 'include'
      });
      
      const data = await response.json();
      resultDiv.textContent = JSON.stringify(data, null, 2);
    } catch (error) {
      resultDiv.textContent = `Error: ${error.message}`;
    }
  });

  document.getElementById('testBtn').addEventListener('click', async () => {
    const resultDiv = document.getElementById('testResult');
    
    try {
      const response = await fetch(`${baseUrl}/api/admin/bookings`, {
        credentials: 'include'
      });
      
      const data = await response.json();
      resultDiv.textContent = `Status: ${response.status}\n\n${JSON.stringify(data, null, 2)}`;
      resultDiv.className = response.ok ? 'bg-muted p-4 rounded text-xs overflow-auto max-h-96 border-2 border-green-500' : 'bg-muted p-4 rounded text-xs overflow-auto max-h-96 border-2 border-red-500';
    } catch (error) {
      resultDiv.textContent = `Error: ${error.message}`;
      resultDiv.className = 'bg-muted p-4 rounded text-xs overflow-auto max-h-96 border-2 border-red-500';
    }
  });
</script>

