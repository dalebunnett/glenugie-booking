---
// Debug page to test authentication
---

<html>
<head>
  <title>Auth Debug</title>
  <style>
    body {
      font-family: monospace;
      padding: 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .section {
      margin: 2rem 0;
      padding: 1rem;
      border: 1px solid #ccc;
      border-radius: 4px;
    }
    button {
      padding: 0.5rem 1rem;
      margin: 0.5rem;
      cursor: pointer;
    }
    .success { color: green; }
    .error { color: red; }
    pre {
      background: #f5f5f5;
      padding: 1rem;
      overflow-x: auto;
    }
  </style>
</head>
<body>
  <h1>🔐 Authentication Debug Tool</h1>
  
  <div class="section">
    <h2>1. Test Login</h2>
    <input type="password" id="password" placeholder="Enter admin password" value="Peterhead2026!" />
    <button onclick="testLogin()">Test Login</button>
    <div id="loginResult"></div>
  </div>

  <div class="section">
    <h2>2. Check Token</h2>
    <button onclick="checkToken()">Verify Current Token</button>
    <div id="tokenResult"></div>
  </div>

  <div class="section">
    <h2>3. Test Admin API</h2>
    <button onclick="testAdminAPI()">Test GET /api/admin/bookings</button>
    <div id="apiResult"></div>
  </div>

  <div class="section">
    <h2>4. Environment Check</h2>
    <button onclick="checkEnv()">Check Environment</button>
    <div id="envResult"></div>
  </div>

  <div class="section">
    <h2>5. Clear Session</h2>
    <button onclick="logout()">Logout & Clear Cookies</button>
    <div id="logoutResult"></div>
  </div>

  <script>
    async function testLogin() {
      const password = document.getElementById('password').value;
      const result = document.getElementById('loginResult');
      result.innerHTML = 'Testing...';

      try {
        const response = await fetch('/api/admin/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password })
        });

        const data = await response.json();
        
        if (response.ok) {
          result.innerHTML = `<div class="success">✅ Login successful!</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>
            <p>Token saved in cookie: admin_session</p>`;
        } else {
          result.innerHTML = `<div class="error">❌ Login failed</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        }
      } catch (error) {
        result.innerHTML = `<div class="error">❌ Error: ${error.message}</div>`;
      }
    }

    async function checkToken() {
      const result = document.getElementById('tokenResult');
      result.innerHTML = 'Checking...';

      try {
        const response = await fetch('/api/admin/auth', {
          method: 'GET'
        });

        const data = await response.json();
        
        if (response.ok && data.valid) {
          result.innerHTML = `<div class="success">✅ Token is valid</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        } else {
          result.innerHTML = `<div class="error">❌ Token is invalid or expired</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        }
      } catch (error) {
        result.innerHTML = `<div class="error">❌ Error: ${error.message}</div>`;
      }
    }

    async function testAdminAPI() {
      const result = document.getElementById('apiResult');
      result.innerHTML = 'Testing...';

      try {
        const response = await fetch('/api/admin/bookings', {
          method: 'GET'
        });

        const data = await response.json();
        
        if (response.ok) {
          result.innerHTML = `<div class="success">✅ Admin API accessible</div>
            <p>Found ${data.bookings?.length || 0} bookings</p>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        } else {
          result.innerHTML = `<div class="error">❌ Admin API denied (Status: ${response.status})</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        }
      } catch (error) {
        result.innerHTML = `<div class="error">❌ Error: ${error.message}</div>`;
      }
    }

    async function checkEnv() {
      const result = document.getElementById('envResult');
      result.innerHTML = 'Checking...';

      const cookies = document.cookie;
      const hasAdminSession = cookies.includes('admin_session=');

      result.innerHTML = `
        <h3>Browser Cookies:</h3>
        <pre>${cookies || 'No cookies'}</pre>
        <p>Has admin_session cookie: ${hasAdminSession ? '✅ Yes' : '❌ No'}</p>
        
        <h3>Current URL:</h3>
        <pre>${window.location.href}</pre>
      `;
    }

    async function logout() {
      const result = document.getElementById('logoutResult');
      result.innerHTML = 'Logging out...';

      try {
        const response = await fetch('/api/admin/auth', {
          method: 'DELETE'
        });

        const data = await response.json();
        
        if (response.ok) {
          result.innerHTML = `<div class="success">✅ Logged out successfully</div>
            <p>Cookie cleared. Try testing login again.</p>`;
        } else {
          result.innerHTML = `<div class="error">❌ Logout failed</div>
            <pre>${JSON.stringify(data, null, 2)}</pre>`;
        }
      } catch (error) {
        result.innerHTML = `<div class="error">❌ Error: ${error.message}</div>`;
      }
    }
  </script>
</body>
</html>
