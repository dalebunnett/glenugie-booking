



---
import MainLayout from '../../layouts/main.astro';
import { baseUrl } from '../../lib/base-url';
---

<MainLayout title="Test Lapdog Land - Admin">
  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="bg-white rounded-lg shadow-lg p-8">
      <h1 class="text-3xl font-bold mb-6">Lapdog Land Diagnostic Tool</h1>
      
      <div class="space-y-4">
        <!-- Step 0: Check ALL Bookings -->
        <div class="border rounded-lg p-4 bg-yellow-50">
          <h2 class="text-xl font-semibold mb-3">Step 0: Check ALL Bookings</h2>
          <p class="text-sm text-gray-600 mb-3">
            This will show ALL bookings in the system and their suite names.
          </p>
          <button 
            id="checkAllButton"
            class="bg-yellow-600 text-white px-4 py-2 rounded hover:bg-yellow-700"
          >
            Check All Bookings
          </button>
          <div id="allResult" class="mt-3 hidden">
            <div id="allSummary" class="mb-3 p-3 bg-white rounded border"></div>
            <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto max-h-96"></pre>
          </div>
        </div>

        <!-- Step 1: Check Database -->
        <div class="border rounded-lg p-4">
          <h2 class="text-xl font-semibold mb-3">Step 1: Check Database</h2>
          <p class="text-sm text-gray-600 mb-3">
            This will show all bookings that contain "lapdog" in any field.
          </p>
          <button 
            id="checkDbButton"
            class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700"
          >
            Check Database
          </button>
          <div id="dbResult" class="mt-3 hidden">
            <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto max-h-96"></pre>
          </div>
        </div>

        <!-- Step 2: Test API Endpoint -->
        <div class="border rounded-lg p-4">
          <h2 class="text-xl font-semibold mb-3">Step 2: Test API Endpoint</h2>
          <p class="text-sm text-gray-600 mb-3">
            This will test the availability API for different slug variations.
          </p>
          <div class="flex gap-2 flex-wrap">
            <button 
              class="test-api-button bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700"
              data-slug="lapdog-land-suite"
            >
              Test: lapdog-land-suite
            </button>
            <button 
              class="test-api-button bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700"
              data-slug="lapdog-land"
            >
              Test: lapdog-land
            </button>
            <button 
              class="test-api-button bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700"
              data-slug="lapdogland"
            >
              Test: lapdogland
            </button>
          </div>
          <div id="apiResult" class="mt-3 hidden">
            <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto max-h-96"></pre>
          </div>
        </div>

        <!-- Step 3: Run Fix -->
        <div class="border rounded-lg p-4">
          <h2 class="text-xl font-semibold mb-3">Step 3: Run Fix</h2>
          <p class="text-sm text-gray-600 mb-3">
            This will update all bookings with old slugs to use "lapdog-land-suite".
          </p>
          <button 
            id="fixButton"
            class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700"
          >
            Fix Lapdog Slugs
          </button>
          <div id="fixResult" class="mt-3 hidden">
            <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto max-h-96"></pre>
          </div>
        </div>

        <!-- Step 4: Verify Fix -->
        <div class="border rounded-lg p-4">
          <h2 class="text-xl font-semibold mb-3">Step 4: Verify Fix</h2>
          <p class="text-sm text-gray-600 mb-3">
            After running the fix, check the database again to verify changes.
          </p>
          <button 
            id="verifyButton"
            class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700"
          >
            Verify Fix
          </button>
          <div id="verifyResult" class="mt-3 hidden">
            <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto max-h-96"></pre>
          </div>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t">
        <a href={`${baseUrl}/admin`} class="text-primary hover:underline">
          ← Back to Admin Dashboard
        </a>
      </div>
    </div>
  </div>

  <script define:vars={{ baseUrl }}>
    // Helper to show result
    function showResult(elementId, data) {
      const resultDiv = document.getElementById(elementId);
      const pre = resultDiv?.querySelector('pre');
      if (pre) {
        pre.textContent = JSON.stringify(data, null, 2);
      }
      resultDiv?.classList.remove('hidden');
    }

    // Step 0: Check ALL Bookings
    document.getElementById('checkAllButton')?.addEventListener('click', async () => {
      const button = document.getElementById('checkAllButton');
      button.disabled = true;
      button.textContent = 'Checking...';

      try {
        const response = await fetch(`${baseUrl}/api/debug/all-bookings`);
        const data = await response.json();
        
        // Show visual summary
        const summaryDiv = document.getElementById('allSummary');
        if (summaryDiv && data.suiteBreakdown) {
          let html = '<h3 class="font-bold mb-2">Suite Breakdown:</h3><div class="space-y-1">';
          Object.entries(data.suiteBreakdown).sort((a, b) => b[1] - a[1]).forEach(([suite, count]) => {
            const isLapdog = suite.toLowerCase().includes('lapdog');
            const bgColor = isLapdog ? 'bg-yellow-100 border-yellow-400' : 'bg-gray-50';
            html += `<div class="flex justify-between p-2 rounded border ${bgColor}">
              <span class="font-mono text-sm">${suite || '(empty)'}</span>
              <span class="font-bold">${count} booking${count !== 1 ? 's' : ''}</span>
            </div>`;
          });
          html += '</div>';
          summaryDiv.innerHTML = html;
        }
        
        showResult('allResult', data);
        button.textContent = `✓ Found ${data.totalBookings} total bookings`;
        button.classList.remove('bg-yellow-600');
        button.classList.add('bg-green-600');
      } catch (error) {
        showResult('allResult', { error: error.message });
        button.textContent = '✗ Error';
        button.classList.remove('bg-yellow-600');
        button.classList.add('bg-red-600');
      } finally {
        setTimeout(() => { button.disabled = false; }, 2000);
      }
    });

    // Step 1: Check Database
    document.getElementById('checkDbButton')?.addEventListener('click', async () => {
      const button = document.getElementById('checkDbButton');
      button.disabled = true;
      button.textContent = 'Checking...';

      try {
        const response = await fetch(`${baseUrl}/api/debug/lapdog-bookings`);
        const data = await response.json();
        showResult('dbResult', data);
        button.textContent = `✓ Found ${data.lapdogBookings} bookings`;
        button.classList.add('bg-green-600');
      } catch (error) {
        showResult('dbResult', { error: error.message });
        button.textContent = '✗ Error';
        button.classList.add('bg-red-600');
      } finally {
        setTimeout(() => { button.disabled = false; }, 2000);
      }
    });

    // Step 2: Test API Endpoints
    document.querySelectorAll('.test-api-button').forEach(button => {
      button.addEventListener('click', async () => {
        const slug = button.getAttribute('data-slug');
        button.disabled = true;
        button.textContent = 'Testing...';

        try {
          const response = await fetch(`${baseUrl}/api/availability/${slug}`);
          const data = await response.json();
          showResult('apiResult', {
            slug,
            status: response.status,
            data
          });
          button.textContent = `✓ ${data.total || 0} bookings`;
          button.classList.remove('bg-purple-600');
          button.classList.add('bg-green-600');
        } catch (error) {
          showResult('apiResult', { slug, error: error.message });
          button.textContent = '✗ Error';
          button.classList.remove('bg-purple-600');
          button.classList.add('bg-red-600');
        } finally {
          setTimeout(() => { 
            button.disabled = false;
            button.classList.remove('bg-green-600', 'bg-red-600');
            button.classList.add('bg-purple-600');
            button.textContent = `Test: ${slug}`;
          }, 3000);
        }
      });
    });

    // Step 3: Run Fix
    document.getElementById('fixButton')?.addEventListener('click', async () => {
      const button = document.getElementById('fixButton');
      button.disabled = true;
      button.textContent = 'Fixing...';

      try {
        const sessionId = localStorage.getItem('admin_session');
        const response = await fetch(`${baseUrl}/api/admin/fix-lapdog-slug`, {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Authorization': `Bearer ${sessionId || ''}`
          }
        });
        const data = await response.json();
        showResult('fixResult', data);
        button.textContent = `✓ Fixed ${data.fixedCount || 0} bookings`;
        button.classList.add('bg-green-600');
      } catch (error) {
        showResult('fixResult', { error: error.message });
        button.textContent = '✗ Error';
        button.classList.add('bg-red-600');
      } finally {
        setTimeout(() => { button.disabled = false; }, 2000);
      }
    });

    // Step 4: Verify Fix
    document.getElementById('verifyButton')?.addEventListener('click', async () => {
      const button = document.getElementById('verifyButton');
      button.disabled = true;
      button.textContent = 'Verifying...';

      try {
        const response = await fetch(`${baseUrl}/api/debug/lapdog-bookings`);
        const data = await response.json();
        showResult('verifyResult', data);
        
        const hasOldSlugs = data.bookings.some(b => 
          b.specificSuite === 'lapdog-land' || b.accommodationType === 'lapdog-land'
        );
        
        if (hasOldSlugs) {
          button.textContent = '⚠️ Still has old slugs!';
          button.classList.add('bg-yellow-600');
        } else {
          button.textContent = '✓ All slugs correct!';
          button.classList.add('bg-green-600');
        }
      } catch (error) {
        showResult('verifyResult', { error: error.message });
        button.textContent = '✗ Error';
        button.classList.add('bg-red-600');
      } finally {
        setTimeout(() => { button.disabled = false; }, 2000);
      }
    });
  </script>
</MainLayout>




