---
import MainLayout from '../../layouts/main.astro';
import { baseUrl } from '../../lib/base-url';
---

<MainLayout title="Remove Village Duplicates - Admin">
  <main class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold mb-6">Remove Village Duplicate Bookings</h1>
      
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <p class="text-yellow-800">
          <strong>⚠️ Warning:</strong> This will permanently delete duplicate Village bookings. 
          The most recent booking for each customer/date combination will be kept.
        </p>
      </div>

      <div class="space-y-4">
        <button
          id="previewBtn"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
        >
          1. Preview Duplicates (Safe)
        </button>

        <button
          id="removeBtn"
          class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
        >
          2. Remove Duplicates (Permanent)
        </button>
      </div>

      <div id="results" class="mt-6"></div>
    </div>
  </main>
</MainLayout>

<script define:vars={{ baseUrl }}>
  const previewBtn = document.getElementById('previewBtn');
  const removeBtn = document.getElementById('removeBtn');
  const resultsDiv = document.getElementById('results');

  previewBtn?.addEventListener('click', async () => {
    resultsDiv.innerHTML = '<p class="text-gray-600">Loading...</p>';
    
    try {
      const response = await fetch(`${baseUrl}/api/admin/remove-duplicate-village`);
      const data = await response.json();
      
      if (data.error) {
        resultsDiv.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <p class="text-red-800"><strong>Error:</strong> ${data.error}</p>
        </div>`;
        return;
      }

      let html = `<div class="bg-white border rounded-lg p-6">
        <h2 class="text-xl font-bold mb-4">Preview Results</h2>
        <div class="space-y-2 mb-4">
          <p><strong>Total Village Bookings:</strong> ${data.totalVillageBookings}</p>
          <p><strong>Duplicate Groups Found:</strong> ${data.duplicateGroups}</p>
        </div>`;

      if (data.duplicates && data.duplicates.length > 0) {
        html += '<div class="space-y-4">';
        data.duplicates.forEach(dup => {
          html += `<div class="border-l-4 border-yellow-400 pl-4">
            <p class="font-semibold">${dup.key}</p>
            <p class="text-sm text-gray-600">${dup.count} duplicate(s)</p>
            <ul class="mt-2 space-y-1 text-sm">`;
          
          dup.bookings.forEach((booking, idx) => {
            const isNewest = idx === 0;
            html += `<li class="${isNewest ? 'text-green-600 font-semibold' : 'text-red-600'}">
              ${isNewest ? '✓ KEEP' : '✗ DELETE'}: ${booking.id.substring(0, 8)}... - 
              ${booking.checkIn} to ${booking.checkOut} - 
              Created: ${new Date(booking.createdAt).toLocaleString()}
            </li>`;
          });
          
          html += '</ul></div>';
        });
        html += '</div>';
      } else {
        html += '<p class="text-green-600">No duplicates found! ✓</p>';
      }

      html += '</div>';
      resultsDiv.innerHTML = html;
    } catch (error) {
      resultsDiv.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <p class="text-red-800"><strong>Error:</strong> ${error.message}</p>
      </div>`;
    }
  });

  removeBtn?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to remove duplicate Village bookings? This cannot be undone!')) {
      return;
    }

    resultsDiv.innerHTML = '<p class="text-gray-600">Removing duplicates...</p>';
    
    try {
      const response = await fetch(`${baseUrl}/api/admin/remove-duplicate-village`, {
        method: 'POST'
      });
      const data = await response.json();
      
      if (data.error) {
        resultsDiv.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <p class="text-red-800"><strong>Error:</strong> ${data.error}</p>
        </div>`;
        return;
      }

      let html = `<div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h2 class="text-xl font-bold mb-4 text-green-800">✓ Duplicates Removed Successfully</h2>
        <div class="space-y-2">
          <p><strong>Total Village Bookings:</strong> ${data.totalVillageBookings}</p>
          <p><strong>Duplicate Groups:</strong> ${data.duplicateGroups}</p>
          <p class="text-green-600"><strong>Kept:</strong> ${data.kept} booking(s)</p>
          <p class="text-red-600"><strong>Deleted:</strong> ${data.deleted} booking(s)</p>
        </div>`;

      if (data.details && data.details.length > 0) {
        html += '<div class="mt-4"><h3 class="font-semibold mb-2">Details:</h3><ul class="space-y-1 text-sm">';
        data.details.forEach(detail => {
          html += `<li>${detail.key}: ${detail.count} duplicates processed</li>`;
        });
        html += '</ul></div>';
      }

      html += '</div>';
      resultsDiv.innerHTML = html;
    } catch (error) {
      resultsDiv.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <p class="text-red-800"><strong>Error:</strong> ${error.message}</p>
      </div>`;
    }
  });
</script>
