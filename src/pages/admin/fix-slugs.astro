---
import MainLayout from '../../layouts/main.astro';
import { Button } from '../../components/ui/button';
---

<MainLayout title="Fix Suite Slugs - Admin">
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold mb-6">Fix Suite Slugs Migration</h1>
      
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 mb-6">
        <h2 class="text-xl font-semibold mb-2">⚠️ What This Does</h2>
        <p class="mb-4">
          This migration will fix all bookings that have suite names (e.g., "Lapdog land Suite") 
          and convert them to proper slugs (e.g., "lapdog-land-suite").
        </p>
        <p class="text-sm text-gray-600">
          This is necessary because imported bookings used display names instead of slugs, 
          which prevents the availability calendar from working correctly.
        </p>
      </div>

      <div id="result" class="hidden mb-6"></div>

      <Button id="runMigration" size="lg" class="w-full">
        🔧 Run Migration
      </Button>

      <div id="loading" class="hidden mt-4 text-center">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        <p class="mt-2 text-gray-600">Running migration...</p>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { baseUrl } from '../../lib/base-url';

  const runButton = document.getElementById('runMigration') as HTMLButtonElement;
  const loading = document.getElementById('loading') as HTMLDivElement;
  const resultDiv = document.getElementById('result') as HTMLDivElement;

  runButton?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to run this migration? This will update all bookings in the database.')) {
      return;
    }

    runButton.disabled = true;
    loading.classList.remove('hidden');
    resultDiv.classList.add('hidden');

    try {
      const response = await fetch(`${baseUrl}/api/admin/fix-suite-slugs`, {
        method: 'POST',
        credentials: 'include'
      });

      const data = await response.json();

      if (data.success) {
        resultDiv.className = 'bg-green-50 border border-green-200 rounded-lg p-6 mb-6';
        resultDiv.innerHTML = `
          <h2 class="text-xl font-semibold text-green-800 mb-2">✅ Migration Successful!</h2>
          <p class="mb-4">Fixed ${data.fixedCount} out of ${data.totalBookings} bookings.</p>
          ${data.updates && data.updates.length > 0 ? `
            <details class="mt-4">
              <summary class="cursor-pointer font-semibold">View Updates (first 20)</summary>
              <pre class="mt-2 text-xs bg-white p-4 rounded overflow-auto max-h-96">${data.updates.join('\n')}</pre>
            </details>
          ` : ''}
          <p class="mt-4 text-sm text-green-700">
            The availability calendar should now work correctly! 🎉
          </p>
        `;
      } else {
        resultDiv.className = 'bg-red-50 border border-red-200 rounded-lg p-6 mb-6';
        resultDiv.innerHTML = `
          <h2 class="text-xl font-semibold text-red-800 mb-2">❌ Migration Failed</h2>
          <p class="mb-2">${data.error || 'Unknown error'}</p>
          ${data.stack ? `<pre class="text-xs bg-white p-4 rounded overflow-auto">${data.stack}</pre>` : ''}
        `;
      }

      resultDiv.classList.remove('hidden');
    } catch (error: any) {
      resultDiv.className = 'bg-red-50 border border-red-200 rounded-lg p-6 mb-6';
      resultDiv.innerHTML = `
        <h2 class="text-xl font-semibold text-red-800 mb-2">❌ Error</h2>
        <p>${error.message}</p>
      `;
      resultDiv.classList.remove('hidden');
    } finally {
      loading.classList.add('hidden');
      runButton.disabled = false;
    }
  });
</script>
