---
import MainLayout from '../../layouts/main.astro';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/card';
import { Button } from '../../components/ui/button';
import { baseUrl } from '../../lib/base-url';
---

<MainLayout pageClass="">
  <div class="min-h-screen bg-background flex items-center justify-center py-16">
    <div class="container mx-auto px-4 max-w-2xl">
      <Card>
        <CardHeader>
          <div class="text-center mb-4">
            <div class="w-16 h-16 bg-yellow-100 dark:bg-yellow-900/20 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
            </div>
            <CardTitle className="text-3xl">Booking Cancelled</CardTitle>
          </div>
        </CardHeader>
        <CardContent>
          <div class="space-y-6 text-center">
            <p class="text-lg">
              Your booking was cancelled and no payment was taken.
            </p>

            <p class="text-muted-foreground">
              If you'd like to try again or have any questions, please feel free to contact us 
              or start a new booking.
            </p>

            <div class="flex gap-4 justify-center pt-4">
              <a href={`${baseUrl}/booking`}>
                <Button>Try Again</Button>
              </a>
              <a href={`${baseUrl}/contact`}>
                <Button variant="outline">Contact Us</Button>
              </a>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</MainLayout>
